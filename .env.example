TELEGRAM_BOT_TOKEN=replace-with-token-from-botfather
LOG_LEVEL=INFO

# Optional: Instagram authentication. The bot looks up the session file first.
# If missing AND INSTAGRAM_PASSWORD is set, it logs in and saves the session.
# Subsequent runs reuse the saved session instead of re-logging in.
#
# Recommended: use a burner Instagram account, not your main one.
# 2FA-protected accounts: programmatic login won't work — instead run
#   `uv run instaloader -l YOUR_USERNAME`
# once interactively, then leave INSTAGRAM_PASSWORD empty.
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_SESSION_FILE=
