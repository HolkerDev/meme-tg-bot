TELEGRAM_BOT_TOKEN=replace-with-token-from-botfather
LOG_LEVEL=INFO
# Optional: enable logged-in Instagram fetches.
# 1. Run `uv run instaloader -l YOUR_USERNAME` once. It saves a session file under
#    ~/.config/instaloader/session-YOUR_USERNAME (Linux) or the platform-specific path.
# 2. Set INSTAGRAM_USERNAME to that username. Leave INSTAGRAM_SESSION_FILE empty to use
#    the default location, or set it to an absolute path if you stored the file elsewhere.
INSTAGRAM_USERNAME=
INSTAGRAM_SESSION_FILE=
